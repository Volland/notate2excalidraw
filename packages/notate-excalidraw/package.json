{
  "name": "@notate/excalidraw",
  "version": "0.1.0",
  "description": "Convert between the notate document model and Excalidraw scenes; mermaid -> notate.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@notate/codec": "0.1.0"
  },
  "peerDependencies": {
    "@excalidraw/mermaid-to-excalidraw": ">=1.1.0"
  },
  "peerDependenciesMeta": {
    "@excalidraw/mermaid-to-excalidraw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
